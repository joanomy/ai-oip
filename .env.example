# Copy this file to .env and adjust for your environment.
# .env is git-ignored — never commit real secrets.
#
# All values below map directly to fields in
# src/ai_oip/config/settings.py::Settings. If you add a new setting,
# document it here in the same PR.

# One of: development | staging | production
ENVIRONMENT=development

APP_NAME=AI-OIP
APP_VERSION=0.0.1

# One of: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Must be false when ENVIRONMENT=production (enforced at startup)
DEBUG=true

# Must use the asyncpg driver (postgresql+asyncpg://...) — enforced at
# startup. Must also be explicitly overridden (not this local default)
# when ENVIRONMENT=production — also enforced at startup.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_oip_dev
